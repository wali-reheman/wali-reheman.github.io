---
layout: default
---
<section class="home-hero">
  <div class="container home-hero__inner">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1 class="home-hero__name">
          {% if site.title == 'blank' %}
            <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
            {{ site.last_name }}
          {% else %}
            {{ site.title }}
          {% endif %}
        </h1>
        <p class="home-hero__subtitle">{{ page.subtitle }}</p>
        {% if page.tagline %}
          <p class="home-hero__tagline">{{ page.tagline }}</p>
        {% endif %}
        {% if page.research_one_liner %}
          <p class="home-hero__agenda">{{ page.research_one_liner }}</p>
        {% endif %}
      </div>

      {% if page.profile.image %}
        <div class="col-md-4 text-center">
          <img src="{{ page.profile.image }}" class="home-hero__image" alt="Profile image">
        </div>
      {% endif %}
    </div>
  </div>
</section>

<div class="container home-main">
  <article class="home-content">
    <div class="clearfix">{{ content }}</div>
  </article>

  {% if site.latest_posts.enabled %}
    <section class="home-block">
      <h2 class="home-block__title"><a href="{{ '/blog/' | relative_url }}">Latest Posts</a></h2>
      {% include latest_posts.liquid %}
    </section>
  {% endif %}

  {% if page.social %}
    <section class="home-social text-center social">
      <div class="contact-icons">{% include social.liquid %}</div>
      <div class="contact-note">{{ site.contact_note }}</div>
    </section>
  {% endif %}

  {% if page.news and site.announcements.enabled %}
    <section class="home-block home-news">
      <h2 class="home-block__title"><a href="{{ '/news/' | relative_url }}">News</a></h2>
      {% include news.liquid limit=true %}
    </section>
  {% endif %}
</div>
