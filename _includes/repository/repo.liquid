{% assign repo_url = include.repository | split: '/' %}
{% if site.data.repositories.github_users contains repo_url.first %}
  {% assign show_owner = false %}
{% else %}
  {% assign show_owner = true %}
{% endif %}

<div class="repo p-2">
  <a href="https://github.com/{{ include.repository }}" class="text-decoration-none" target="_blank" rel="noopener noreferrer">
    <div class="card h-100">
      <img
        class="w-100"
        alt="{{ include.repository }}"
        src="https://opengraph.githubassets.com/{{ include.repository | replace: '/', '-' }}/{{ include.repository }}"
        loading="lazy"
        onerror="this.onerror=null;this.src='https://github.com/{{ repo_url[0] }}.png?size=460';"
      >
      <div class="card-body text-left">
        <h5 class="card-title mb-1">{{ repo_url[1] }}</h5>
        {% if show_owner %}
          <p class="mb-2">@{{ repo_url[0] }}</p>
        {% endif %}
        <div class="repo-badges">
          <img
            alt="{{ include.repository }} stars"
            src="https://img.shields.io/github/stars/{{ include.repository }}?style=flat-square&logo=github&label=stars"
            loading="lazy"
            onerror="this.style.display='none';"
          >
          <img
            alt="{{ include.repository }} forks"
            src="https://img.shields.io/github/forks/{{ include.repository }}?style=flat-square&logo=github&label=forks"
            loading="lazy"
            onerror="this.style.display='none';"
          >
          <img
            alt="{{ include.repository }} last commit"
            src="https://img.shields.io/github/last-commit/{{ include.repository }}?style=flat-square&logo=github&label=updated"
            loading="lazy"
            onerror="this.style.display='none';"
          >
        </div>
      </div>
    </div>
  </a>
</div>
