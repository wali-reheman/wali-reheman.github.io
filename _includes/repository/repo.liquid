{% assign repo_url = include.repository | split: '/' %}

<div class="repo p-2">
  <div class="card h-100 repo-card">
    <a href="https://github.com/{{ include.repository }}" class="repo-preview-link" aria-label="{{ include.repository }} repository">
      <img
        class="repo-preview w-100"
        alt="{{ include.repository }}"
        src="https://opengraph.githubassets.com/1/{{ include.repository }}"
        loading="lazy"
        onerror="this.style.display='none';"
      >
    </a>
    <div class="card-body py-3">
      <h5 class="card-title mb-1">
        <a href="https://github.com/{{ include.repository }}">{{ repo_url[1] }}</a>
      </h5>
      <p class="card-text small mb-2 text-muted">{{ include.repository }}</p>
      <div class="repo-meta d-flex flex-wrap align-items-center">
        <img
          class="repo-badge mr-1 mb-1"
          alt="{{ include.repository }} stars"
          src="https://img.shields.io/github/stars/{{ include.repository }}?style=flat-square&logo=github&label=stars&color=f59e0b"
          loading="lazy"
          onerror="this.style.display='none';"
        >
        <img
          class="repo-badge mr-1 mb-1"
          alt="{{ include.repository }} forks"
          src="https://img.shields.io/github/forks/{{ include.repository }}?style=flat-square&logo=github&label=forks&color=1f6feb"
          loading="lazy"
          onerror="this.style.display='none';"
        >
        <img
          class="repo-badge mr-1 mb-1"
          alt="{{ include.repository }} last commit"
          src="https://img.shields.io/github/last-commit/{{ include.repository }}?style=flat-square&logo=github&label=updated&color=6f42c1"
          loading="lazy"
          onerror="this.style.display='none';"
        >
      </div>
    </div>
  </div>
</div>
